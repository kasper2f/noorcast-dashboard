rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(email) {
      return isSignedIn() && request.auth.token.email == email;
    }

    function getEmployee() {
      return get(/databases/$(database)/documents/employees/$(request.auth.uid)).data;
    }

    function isAdmin() {
      return isSignedIn() && getEmployee().role == 'admin';
    }

    function isDepartment(dept) {
      return isSignedIn() && getEmployee().department == dept;
    }

    match /employees/{uid} {
      allow read: if isSignedIn() && request.auth.uid == uid;
      allow write: if false;
    }

    match /finance/{docId} {
      allow read: if isOwner(resource.data.employeeEmail)
                  || isDepartment('finance')
                  || isAdmin();
      allow write: if false;
    }

    match /operations/{docId} {
      allow read: if isOwner(resource.data.employeeEmail)
                  || isDepartment('operations')
                  || isAdmin();
      allow write: if false;
    }

    match /hr/{docId} {
      allow read: if isOwner(resource.data.employeeEmail)
                  || isDepartment('hr')
                  || isAdmin();
      allow write: if false;
    }
  }
}
